{
  "name": "weekly-checkin",
  "version": "1.0.0",
  "description": "Weekly check-in DMs + dashboard for Brand & Social team",
  "main": "src/scheduler.js",
  "scripts": {
    "start": "node src/scheduler.js",
    "send": "node -e \"require('./src/send').sendCheckins()\"",
